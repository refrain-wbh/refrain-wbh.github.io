@techreport{wang2026verification,
  abbr        = {Tech Report},
  bibtex_show = {true},
  title       = {The Verification Horizon: No Silver Bullet for Coding Agent Rewards},
  author      = {Binghai Wang and Chenlong Zhang and Dayiheng Liu and Jiajun Zhang and Jiawei Chen and Mouxiang Chen and Rongyao Fang and Siyuan Zhang and Xuwu Wang and Yuheng Jing and Zeyao Ma and Zeyu Cui},
  journal     = {arXiv preprint arXiv:2606.26300},
  year        = {2026},
  month       = {6},
  arxiv       = {2606.26300},
  doi         = {10.48550/arXiv.2606.26300},
  website     = {/papers/verification-horizon/},
  note        = {Qwen Team Technical Report},
  tldr        = {Verification, not generation, has become the real bottleneck for coding agents—so reward systems must co-evolve with the policy they supervise.},
  abstract    = {A classical intuition holds that verifying a solution is easier than producing one. For today's coding agents, this intuition is being inverted: generating complex candidate solutions is no longer difficult---reliably verifying them has become the harder problem. Every verifier we can build is only a proxy for human intent, never the intent itself. We characterize the quality of verification signals along three dimensions---scalability, faithfulness, and robustness---and study four reward constructions: a test verifier for general coding tasks, a rubric verifier for frontend tasks, the user as verifier for real-world agent tasks, and an automated agent verifier for long-horizon tasks. No fixed reward function can remain effective as policy capability continues to grow; verification must co-evolve with the generator.},
  selected    = {true}
}

@inproceedings{xi2026agentprm,
  abbr        = {WWW'26},
  bibtex_show = {true},
  title       = {AgentPRM: Process Reward Models for LLM Agents via Step-Wise Promise and Progress},
  author      = {Zhiheng Xi and Chenyang Liao and Guanyu Li and Zhihao Zhang and Wenxiang Chen and Binghai Wang and Senjie Jin and Yuhao Zhou and Jian Guan and Wei Wu and Tao Ji and Tao Gui and Qi Zhang and Xuanjing Huang},
  booktitle   = {Proceedings of the ACM Web Conference (WWW)},
  year        = {2026},
  month       = {6},
  arxiv       = {2511.08325},
  doi         = {10.1145/3774904.3792551},
  citations   = {35},
  tldr        = {Process reward models that score each agent step by its "promise" and "progress", improving long-horizon LLM-agent decision-making.},
  abstract    = {We introduce AgentPRM, a process reward model that supervises LLM agents at the step level. Rather than only rewarding final outcomes, AgentPRM scores intermediate steps by their promise (expected future usefulness) and progress (concrete advancement toward the goal), yielding denser and more informative training signals for long-horizon agentic tasks.}
}

@article{pan2026evpo,
  abbr        = {arXiv'26},
  bibtex_show = {true},
  title       = {EVPO: Explained Variance Policy Optimization for Adaptive Critic Utilization in LLM Post-Training},
  author      = {Chengjun Pan and Shichun Liu and Jiahang Lin and Dingwei Zhu and Jiazheng Zhang and Shihan Dou and Songyang Gao and Zhenhua Han and Binghai Wang and Rui Zheng and Xuanjing Huang and Tao Gui and Yansong Feng},
