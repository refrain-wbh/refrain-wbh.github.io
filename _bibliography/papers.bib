  doi         = {10.48550/arXiv.2604.19485},
  tldr        = {Uses explained variance to adaptively decide how much to trust the critic, stabilizing and accelerating LLM post-training.},
  abstract    = {EVPO introduces explained-variance policy optimization, which adaptively modulates critic utilization during LLM post-training. By measuring how much variance the critic actually explains, EVPO down-weights an unreliable critic and leans on it when trustworthy, improving training stability and sample efficiency.}
}

